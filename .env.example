# GP Triage POC - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o
TEMPERATURE=0.0
MAX_TOKENS=1000

# Optional: Logging
LOG_LEVEL=INFO

# PostgreSQL / Supabase (leave blank to fall back to local SQLite)
# URL-encode special chars in password: [ = %5B  ] = %5D  & = %26  + = %2B
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ClinisenseAI Ensemble Engine — additional model API keys
# All are optional; ensemble degrades gracefully if keys are missing (min 2 required)
ANTHROPIC_API_KEY=your-claude-api-key
GEMINI_API_KEY=your-gemini-api-key
MISTRAL_API_KEY=your-mistral-api-key

# Email / SMTP (optional — for letter emailing feature)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
