# GP Triage POC - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o
TEMPERATURE=0.0
MAX_TOKENS=1000

# Optional: Logging
LOG_LEVEL=INFO
